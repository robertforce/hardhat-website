{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": "(?i).*text/markdown.*"
        }
      ],
      "headers": [{ "key": "Vary", "value": "Accept" }]
    },
    {
      "source": "/:path((?!.*\\.md$)(?!.*\\.html$)(?!.*\\.txt$).*)",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": "(?i).*text/markdown.*"
        }
      ],
      "headers": [{ "key": "Vary", "value": "Accept" }]
    }
  ],
  "trailingSlash": false,
  "framework": "astro",
  "redirects": [
    {
      "source": "/HHE:number(\\d+)",
      "destination": "/hhe:number",
      "permanent": false
    },
    {
      "source": "/HH:number(\\d+)",
      "destination": "https://v2.hardhat.org/hh:number",
      "permanent": false
    },
    {
      "source": "/hh:number(\\d+)",
      "destination": "https://v2.hardhat.org/hh:number",
      "permanent": false
    },
    {
      "source": "/:path*/index.html",
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": "(?i).*text/markdown.*"
        }
      ],
      "destination": "/index.md",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i).*(claude|codex|opencode|gemini|copilot|cursor|antigravity|anthropic|openai|grok|gpt).*"
        }
      ],
      "destination": "/index.md",
      "permanent": false
    },
    {
      "source": "/:path((?!.*\\.md$)(?!.*\\.html$)(?!.*\\.txt$).*)",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": "(?i).*text/markdown.*"
        }
      ],
      "destination": "/:path.md",
      "permanent": false
    },
    {
      "source": "/:path((?!.*\\.md$)(?!.*\\.html$)(?!.*\\.txt$).*)",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i).*(claude|codex|opencode|gemini|copilot|cursor|antigravity|anthropic|openai|grok|gpt).*"
        }
      ],
      "destination": "/:path.md",
      "permanent": false
    }
  ]
}
