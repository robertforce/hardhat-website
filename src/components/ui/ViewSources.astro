---
const { entry } = Astro.locals.starlightRoute;
const currentPath = Astro.url.pathname;
import { Icon } from "@astrojs/starlight/components";
import { globalConfig } from "../../config";

// We only author content in .mdx. Any .md file is autogenerated at build time, so
// it doesn't have a github url.
const isPageEntryGeneratedByStarlight =
  entry.collection === "docs" && entry.filePath.endsWith(".mdx");
---

<div class="view-page-source-container">
  {
    (
      <>
        <h2>View page source</h2>
        <ul>
          {isPageEntryGeneratedByStarlight && (
            <li class="view-page-source-item">
              <a
                href={`${globalConfig.baseGitHubDeploymentBranchViewUrl}/${entry.filePath}`}
                class="starlight-view-modes-switcher-a"
              >
                <Icon name="seti:github" /> On GitHub
              </a>
            </li>
          )}
          <li class="view-page-source-item">
            <a
              href={`${currentPath}.md`}
              class="starlight-view-modes-switcher-a"
            >
              <Icon name="seti:markdown" /> Markdown version
            </a>
          </li>
        </ul>
      </>
    )
  }
</div>

<style>
  .view-page-source-container {
    margin-top: 1rem;
  }
  .view-page-source-container ul {
    padding: 0;
    list-style: none;
  }
  .view-page-source-container a {
    --pad-inline: 0.5rem;
    display: block;
    border-radius: 0.25rem;
    padding-block: 0.25rem;
    padding-inline: var(--pad-inline);
    line-height: 1.25;
  }

  .view-page-source-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .view-page-source-item svg {
    margin-right: 0.2rem;
    height: 1rem;
    vertical-align: text-bottom;
  }

  .sl-container {
    display: block;
  }
</style>
